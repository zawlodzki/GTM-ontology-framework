{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/binding.schema.json",
  "title": "GOF Binding (A6)",
  "type": "object",
  "required": ["kind", "id", "system", "meta", "objects"],
  "properties": {
    "kind": {"const": "binding"},
    "id": {"type": "string"},
    "system": {"type": "string", "pattern": "^system:"},
    "meta": {"$ref": "#/$defs/meta"},
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["object", "entity", "id_field", "properties"],
        "properties": {
          "object": {"type": "string", "pattern": "^object:"},
          "entity": {"type": "string"},
          "id_field": {"type": "string"},
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["property", "field_key", "writable"],
              "properties": {
                "property": {"type": "string"},
                "field_key": {"type": "string"},
                "transform": {"enum": ["none", "enum_options", "currency", "datetime_tz", "expression"]},
                "enum_map": {"type": "object"},
                "expression": {"type": "string"},
                "datetime": {
                  "type": "object",
                  "description": "How a date/datetime field serializes at this system's boundary. Defaults come from the system's data_standards; set here only to be explicit or to override for one field. Required semantics: transform:datetime_tz means precision:datetime and a tz conversion from source_tz to the API timezone; a date-only field uses transform:none and precision:date and is NEVER tz-converted.",
                  "properties": {
                    "precision": {"enum": ["date", "datetime"], "description": "date = no timezone, sent verbatim; datetime = converted from source_tz to the system's api_timezone before writing, and back on read."},
                    "source_tz": {"type": "string", "description": "IANA zone a naive incoming value is authored in. Defaults to the system's data_standards.business_timezone."}
                  }
                },
                "writable": {"type": "boolean"},
                "visibility": {
                  "type": "object",
                  "properties": {
                    "pipelines": {"type": "array", "items": {"type": "string"}},
                    "important_on_stage": {"type": "string"}
                  }
                },
                "notes": {"type": "string"}
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["source", "status"],
      "properties": {
        "source": {"enum": ["discovered", "inferred", "declared", "learned"]},
        "status": {"enum": ["draft", "confirmed"]},
        "confirmed_by": {"type": "string"},
        "updated": {"type": "string"},
        "evidence": {"type": "string"},
        "last_verified": {"type": "string", "format": "date"},
        "verify_every": {"type": "string", "pattern": "^[0-9]+[dwmy]$"},
        "valid_from": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date"}
      }
    }
  }
}
