{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/product-group-manifest.schema.json",
  "title": "GOF Product-Group Manifest",
  "type": "object",
  "required": ["kind", "id", "version", "updated", "name", "summary", "artifacts"],
  "properties": {
    "kind": {"const": "product-group-manifest"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "updated": {"type": "string", "format": "date"},
    "example": {"type": "boolean"},
    "language": {"type": "string"},
    "name": {"type": "string"},
    "summary": {"type": "string"},
    "inherits": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"}},
    "agent_instructions": {"type": "string"},
    "artifacts": {"$ref": "#/$defs/entries"},
    "products": {"$ref": "#/$defs/entries"}
  },
  "$defs": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "path", "summary"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
          "kind": {"type": "string"},
          "path": {"type": "string"},
          "summary": {"type": "string", "maxLength": 140},
          "load_when": {"type": "string"}
        }
      }
    }
  }
}
