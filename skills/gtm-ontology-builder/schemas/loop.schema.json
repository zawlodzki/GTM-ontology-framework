{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/loop.schema.json",
  "title": "GOF Loop (A15)",
  "type": "object",
  "required": ["kind", "id", "name", "description", "meta", "owner", "permission_level", "refs", "metrics", "journal"],
  "properties": {
    "kind": {"const": "loop"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "meta": {"$ref": "#/$defs/meta"},
    "owner": {"type": "string"},
    "agent": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "permission_level": {"type": "integer", "minimum": 1},
    "target_level": {"type": "integer", "minimum": 1},
    "promotion_criteria": {"type": "array", "items": {"type": "string"}},
    "refs": {
      "type": "object",
      "required": ["actions"],
      "properties": {
        "actions": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^action:"}},
        "prompts": {"type": "array", "items": {"type": "string", "pattern": "^prompt:"}},
        "process": {"type": "string", "pattern": "^process:"}
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "cadence"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
          "description": {"type": "string"},
          "cadence": {"type": "string"},
          "target": {"type": "string"}
        }
      }
    },
    "journal": {"type": "string"},
    "escalation": {"type": "string"}
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["source", "status"],
      "properties": {
        "source": {"enum": ["discovered", "inferred", "declared", "learned"]},
        "status": {"enum": ["draft", "confirmed"]},
        "confirmed_by": {"type": "string"},
        "updated": {"type": "string"},
        "evidence": {"type": "string"},
        "last_verified": {"type": "string", "format": "date"},
        "verify_every": {"type": "string", "pattern": "^[0-9]+[dwmy]$"},
        "valid_from": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date"}
      }
    }
  }
}
