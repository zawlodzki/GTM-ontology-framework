{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/action.schema.json",
  "title": "GOF Agent Action (A10)",
  "type": "object",
  "required": ["kind", "id", "name", "description", "meta", "object", "intent", "executor", "approval", "preconditions", "inputs", "workflow", "effects", "side_effects", "idempotency", "implementations"],
  "properties": {
    "kind": {"const": "action"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "meta": {"$ref": "#/$defs/meta"},
    "object": {"type": "string", "pattern": "^object:"},
    "intent": {"type": "string"},
    "executor": {"enum": ["agent", "human", "either"]},
    "approval": {"enum": ["none", "required", "conditional"]},
    "approval_condition": {"type": "string"},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_static_refs", "required_live_refs", "optional_refs", "forbidden_to_persist", "response_mode"],
      "properties": {
        "required_static_refs": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9./_-]*$"},
          "uniqueItems": true
        },
        "required_live_refs": {
          "type": "array",
          "items": {"type": "string", "pattern": "^property:[a-z0-9]+(-[a-z0-9]+)*\\.[a-z0-9_]+$"},
          "uniqueItems": true
        },
        "optional_refs": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-z][a-z0-9-]*:[a-z0-9][a-z0-9./_-]*$"},
          "uniqueItems": true
        },
        "forbidden_to_persist": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(input:[a-zA-Z0-9_-]+|property:[a-z0-9]+(-[a-z0-9]+)*\\.[a-z0-9_]+)$"
          },
          "uniqueItems": true
        },
        "response_mode": {"enum": ["concise", "detailed", "file-reference"]}
      }
    },
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {"description": {"type": "string"}, "check": {"type": "string"}}
      }
    },
    "abstain_when": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description"],
        "properties": {"description": {"type": "string"}, "check": {"type": "string"}}
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "required", "description"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "required": {"type": "boolean"},
          "description": {"type": "string"}
        }
      }
    },
    "workflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "description"],
        "properties": {
          "step": {"type": "integer"},
          "description": {"type": "string"},
          "on_failure": {"type": "string"}
        }
      }
    },
    "effects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target", "operation"],
        "properties": {
          "target": {"type": "string"},
          "operation": {"enum": ["write", "create", "delete", "notify", "external"]},
          "detail": {"type": "string"}
        }
      }
    },
    "side_effects": {"type": "array", "items": {"type": "string"}},
    "postconditions": {"type": "array", "items": {"type": "string"}},
    "idempotency": {"enum": ["safe_to_retry", "not_idempotent", "conditional"]},
    "idempotency_notes": {"type": "string"},
    "implementations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["system", "via", "tool_or_endpoint"],
        "properties": {
          "system": {"type": "string", "pattern": "^system:"},
          "via": {"enum": ["mcp", "api", "warehouse"]},
          "tool_or_endpoint": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "error_handling": {"type": "string"}
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["source", "status"],
      "properties": {
        "source": {"enum": ["discovered", "inferred", "declared", "learned"]},
        "status": {"enum": ["draft", "confirmed"]},
        "confirmed_by": {"type": "string"},
        "updated": {"type": "string"},
        "evidence": {"type": "string"},
        "last_verified": {"type": "string", "format": "date"},
        "verify_every": {"type": "string", "pattern": "^[0-9]+[dwmy]$"},
        "valid_from": {"type": "string", "format": "date"},
        "valid_until": {"type": "string", "format": "date"}
      }
    }
  }
}
