{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/object-type.schema.json",
  "title": "GOF Object Type (A3)",
  "type": "object",
  "required": ["kind", "id", "name", "description", "meta", "properties"],
  "properties": {
    "kind": {"const": "object-type"},
    "id": {"$ref": "#/$defs/kebab"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "meta": {"$ref": "#/$defs/meta"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "properties": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/property"}},
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "target", "cardinality"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]*$"},
          "target": {"type": "string", "pattern": "^object:"},
          "cardinality": {"enum": ["one-to-one", "one-to-many", "many-to-one", "many-to-many"]},
          "semantics": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "kebab": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "meta": {
      "type": "object",
      "required": ["source", "status"],
      "properties": {
        "source": {"enum": ["discovered", "inferred", "declared"]},
        "status": {"enum": ["draft", "confirmed"]},
        "confirmed_by": {"type": "string"},
        "updated": {"type": "string"}
      }
    },
    "property": {
      "type": "object",
      "required": ["id", "name", "type", "semantics", "filled_by"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "name": {"type": "string"},
        "type": {"enum": ["string", "text", "number", "currency", "boolean", "date", "datetime", "enum", "set", "reference", "json", "phone", "email", "url", "user", "address"]},
        "semantics": {"type": "string"},
        "filled_by": {"enum": ["human", "automation", "ai", "integration", "system", "mixed"]},
        "filled_by_detail": {"type": "string"},
        "user_access": {"enum": ["editable", "read-only", "mixed"]},
        "required": {},
        "default": {},
        "validation": {"type": "string"},
        "enum": {"type": "array", "items": {"$ref": "#/$defs/enumValue"}},
        "ai": {
          "type": "object",
          "required": ["prompt_ref"],
          "properties": {
            "prompt_ref": {"type": "string", "pattern": "^prompt:"},
            "inputs": {"type": "array", "items": {"type": "string"}},
            "trigger": {"type": "string"},
            "regenerate_policy": {"type": "string"}
          }
        },
        "quality_notes": {"type": "string"},
        "meta": {"$ref": "#/$defs/meta"}
      },
      "if": {"properties": {"type": {"const": "enum"}}},
      "then": {"required": ["id", "name", "type", "semantics", "filled_by", "enum"]}
    },
    "enumValue": {
      "type": "object",
      "required": ["value", "definition", "set_by"],
      "properties": {
        "value": {"type": ["string", "number"]},
        "label": {"type": "string"},
        "definition": {"type": ["string", "null"]},
        "set_by": {"type": "string"},
        "entry_conditions": {"type": "array", "items": {"type": "string"}},
        "reversible": {"type": "boolean"}
      }
    }
  }
}
