{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gof/system.schema.json",
  "title": "GOF System Profile (A4)",
  "type": "object",
  "required": ["kind", "id", "name", "meta", "role", "access", "write_access"],
  "properties": {
    "kind": {"const": "system"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "name": {"type": "string"},
    "meta": {"$ref": "#/$defs/meta"},
    "role": {"enum": ["crm", "email-marketing", "erp", "billing", "support", "enrichment", "automation-platform", "other"]},
    "vendor": {"type": "string"},
    "access": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["via"],
        "properties": {
          "via": {"enum": ["mcp", "api", "warehouse"]},
          "server": {"type": "string"},
          "key_tools": {"type": "array", "items": {"type": "string"}},
          "base_url": {"type": "string"},
          "auth": {"type": "string"},
          "docs_url": {"type": "string"},
          "dataset": {"type": "string"},
          "loaded_by": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "write_access": {"enum": ["none", "limited", "full"]},
    "write_access_notes": {"type": "string"},
    "rate_limits": {"type": "string"},
    "environment_notes": {"type": "string"}
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["source", "status"],
      "properties": {
        "source": {"enum": ["discovered", "inferred", "declared"]},
        "status": {"enum": ["draft", "confirmed"]},
        "confirmed_by": {"type": "string"},
        "updated": {"type": "string"}
      }
    }
  }
}
